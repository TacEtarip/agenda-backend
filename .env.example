DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=agenda_db
JWT_SECRET=replace-with-a-long-random-secret
TYPEORM_SYNC=false
CORS_ORIGIN=http://localhost:4200
PORT=3000
NODE_ENV=development

# whatsapp-web.js consumes one Chromium client per active user. These are
# per-backend-instance safeguards; AWS WAF/routing limits are added at deploy time.
WHATSAPP_MAX_CLIENTS=5
WHATSAPP_QR_TIMEOUT_MS=300000
WHATSAPP_IDLE_TIMEOUT_MS=1800000

# Google OAuth: leave all five values empty to disable the integration.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_FRONTEND_REDIRECT_URL=
# Generate with: openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY=
# Optional in local development (falls back to incremental polling).
# Production example: https://api.example.com/integrations/google/webhook
GOOGLE_CALENDAR_WEBHOOK_URL=

PAYMENT_API_KEY=development-key
PAYMENT_WEBHOOK_SECRET=development-webhook-secret
